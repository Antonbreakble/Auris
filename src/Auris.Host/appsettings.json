{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "AllowedHosts": "*",
  
  "Auris": {
    "Queue": {
      "Capacity": 100
    },
    "AudioLibrary": {
      "RootPath": "D:\\Music"
    },
    "Player": {
      "ExecutablePath": "ffplay",
      "Arguments": [
        "-nodisp",
        "-autoexit",
        "{file}"
      ],
      "WorkingDirectory": "",
      "KillOnCancellation": true
    }
  }
}
