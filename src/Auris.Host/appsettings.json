{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5194"
      }
    }
  },
  
  "AllowedHosts": "*",
  
  "Application": {
    "Queue": {
      "Capacity": 100
    },
    "AudioLibrary": {
      "RootPath": "D:\\AudioLibrary",
      "AllowedExtensions": [
        ".mp3",
        ".wav",
        ".flac",
        ".ogg",
        ".m4a",
        ".aac"
      ]
    },
    "Player": {
      "ExecutablePath": "ffplay",
      "Arguments": [
        "-nodisp",
        "-autoexit",
        "{file}"
      ],
      "WorkingDirectory": "",
      "KillOnCancellation": true
    },
    "TextToSpeech": {
      "Cli": {
        "ExecutablePath": "D:\\tts\\local\\piper.exe",
        "ModelPath": "D:\\tts\\local\\voices\\ru_RU-irina-medium.onnx"
      }
    }
  }
}
