@page
@using Auris.Host.Admin.Services
@model Auris.Host.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "Admin";
}

<div class="mb-4">
    <h1 class="mb-2">@ProductBrand.Name</h1>
    <p class="text-muted mb-0">
        Панель управления локальным аудиосервисом.
    </p>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Сейчас воспроизводится</span>

        <div class="d-flex align-items-center gap-2">
            <button id="stop-playback-button"
                    type="button"
                    class="btn btn-sm btn-outline-danger d-none">
                Остановить
            </button>

            <span id="playback-status-badge"
                  class="badge text-bg-secondary">
                Idle
            </span>
        </div>
    </div>

    <div class="card-body">
        <div id="playback-current-file" class="fw-semibold">
            Сейчас ничего не воспроизводится.
        </div>

        <div id="playback-current-meta" class="text-muted small mt-1"></div>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.QueueTab ? "active" : "")"
           asp-page="/Admin/Index"
           asp-route-tab="@AdminDashboardService.QueueTab">
            Текущая очередь
        </a>
    </li>

    <li class="nav-item">
        <a class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.LibraryTab ? "active" : "")"
           asp-page="/Admin/Index"
           asp-route-tab="@AdminDashboardService.LibraryTab">
            Аудиофайлы
        </a>
    </li>
    
    <li class="nav-item">
        <a
            class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.TextToSpeechTab ? "active" : "")"
            asp-page="/Admin/Index"
            asp-route-tab="@AdminDashboardService.TextToSpeechTab">
            Синтез речи
        </a>
    </li>
</ul>

@if (Model.Dashboard.ActiveTab == AdminDashboardService.QueueTab)
{
    @await Html.PartialAsync("Partials/_QueueTab", Model.Dashboard.Queue)
}

@if (Model.Dashboard.ActiveTab == AdminDashboardService.LibraryTab)
{
    @await Html.PartialAsync("Partials/_LibraryTab", Model.Dashboard.Library)
}

@if (Model.Dashboard.ActiveTab == AdminDashboardService.TextToSpeechTab)
{
    @await Html.PartialAsync("Partials/_TextToSpeechTab")
}

@section Scripts {
    <script>
        
        async function updatePlaybackStatus() {
            try {
                const response = await fetch('/api/audio/status');

                if (!response.ok) {
                    setPlaybackStatusError();
                    return;
                }

                const status = await response.json();

                const badge = document.getElementById('playback-status-badge');
                const currentFile = document.getElementById('playback-current-file');
                const meta = document.getElementById('playback-current-meta');
                const stopButton = document.getElementById('stop-playback-button');
                
                const isPlaying = status.isPlaying ?? status.IsPlaying;
                const state = status.state ?? status.State ?? 'Idle';
                const fileName = status.fileName ?? status.FileName;
                const currentItemId = status.currentItemId ?? status.CurrentItemId;
                const startedAt = status.startedAt ?? status.StartedAt;

                if (isPlaying) {
                    badge.textContent = state;
                    badge.className = 'badge text-bg-success';
                    
                    stopButton.disabled = false;
                    stopButton.textContent = 'Остановить';
                    stopButton.classList.remove('d-none');

                    currentFile.textContent = fileName ?? 'Файл воспроизводится';

                    const metaItems = [];

                    if (currentItemId) {
                        metaItems.push(`ItemId: ${currentItemId}`);
                    }

                    if (startedAt) {
                        const startedDate = new Date(startedAt);
                        metaItems.push(`Started: ${startedDate.toLocaleString()}`);
                    }

                    meta.textContent = metaItems.join(' · ');
                    
                    return;
                }

                badge.textContent = state;
                badge.className = 'badge text-bg-secondary';

                currentFile.textContent = 'Сейчас ничего не воспроизводится.';
                meta.textContent = '';
                
                stopButton.disabled = false;
                stopButton.textContent = 'Остановить';
                stopButton.classList.add('d-none');
            } catch {
                setPlaybackStatusError();
            }
        }

        async function stopCurrentPlayback() {
            const button =
                document.getElementById('stop-playback-button');

            if (!button) {
                return;
            }

            button.disabled = true;
            button.textContent = 'Остановка...';

            try {
                const response = await fetch('/api/audio/current', {
                    method: 'DELETE'
                });

                if (!response.ok && response.status !== 404) {
                    throw new Error(
                        'Не удалось остановить воспроизведение.');
                }

                await updatePlaybackStatus();
            } finally {
                button.disabled = false;
                button.textContent = 'Остановить';
            }
        }

        function setPlaybackStatusError() {
            const badge = document.getElementById('playback-status-badge');
            const currentFile = document.getElementById('playback-current-file');
            const meta = document.getElementById('playback-current-meta');
            document.getElementById('stop-playback-button')?.classList.add('d-none');
            
            badge.textContent = 'Unknown';
            badge.className = 'badge text-bg-warning';

            currentFile.textContent = 'Не удалось получить статус воспроизведения.';
            meta.textContent = '';
        }

        async function updateQueue() {
            const queueCount = document.getElementById('queue-count');
            const queueCapacity = document.getElementById('queue-capacity');
            const queueBody = document.getElementById('queue-table-body');
            const queueEmpty = document.getElementById('queue-empty');
            const queueTableWrapper = document.getElementById('queue-table-wrapper');
            const queueError = document.getElementById('queue-error');

            if (!queueCount || !queueCapacity || !queueBody || !queueEmpty || !queueTableWrapper) {
                return;
            }

            try {
                const response = await fetch('/api/audio/queue');

                if (!response.ok) {
                    setQueueError(true);
                    return;
                }

                const queue = await response.json();

                const count = queue.count ?? queue.Count ?? 0;
                const capacity = queue.capacity ?? queue.Capacity ?? 0;
                const items = queue.items ?? queue.Items ?? [];

                queueCount.textContent = count;
                queueCapacity.textContent = capacity;

                queueBody.innerHTML = '';

                if (items.length === 0) {
                    queueEmpty.classList.remove('d-none');
                    queueTableWrapper.classList.add('d-none');
                    setQueueError(false);
                    return;
                }

                queueEmpty.classList.add('d-none');
                queueTableWrapper.classList.remove('d-none');

                for (const item of items) {
                    queueBody.insertAdjacentHTML('beforeend', renderQueueRow(item));
                }

                setQueueError(false);
            } catch {
                setQueueError(true);
            }
        }

        function renderQueueRow(item) {
            const id = item.id ?? item.Id ?? '';
            const fileName = item.fileName ?? item.FileName ?? '';
            const createdAt = item.createdAt ?? item.CreatedAt;
            const createdBy = item.createdBy ?? item.CreatedBy ?? '';

            return `
                <tr data-queue-item-id="${escapeHtml(id)}">
                    <td>${escapeHtml(fileName)}</td>
                    <td>${formatDateTime(createdAt)}</td>
                    <td>${escapeHtml(createdBy)}</td>
                </tr>`;
        }

        async function clearQueue() {
            try {
                const response = await fetch('/api/audio/queue/clear', {
                    method: 'DELETE'
                });

                if (!response.ok) {
                    setQueueError(true);
                    return;
                }

                await updateQueue();
            } catch {
                setQueueError(true);
            }
        }

        function setQueueError(isError) {
            const queueError = document.getElementById('queue-error');

            if (!queueError) {
                return;
            }

            if (isError) {
                queueError.classList.remove('d-none');
            } else {
                queueError.classList.add('d-none');
            }
        }

        function formatDateTime(value) {
            if (!value) {
                return '';
            }

            const date = new Date(value);

            if (Number.isNaN(date.getTime())) {
                return '';
            }

            return date.toLocaleString();
        }

        function escapeHtml(value) {
            return String(value)
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        document.getElementById('refresh-queue-button')
            ?.addEventListener('click', updateQueue);

        document.getElementById('clear-queue-button')
            ?.addEventListener('click', clearQueue);

        async function enqueueLibraryFile(fileName, button) {
            if (!fileName) {
                showLibraryActionMessage('Не указано имя файла.', 'warning');
                return;
            }

            const originalText = button?.textContent;

            if (button) {
                button.disabled = true;
                button.textContent = 'Добавление...';
            }

            try {
                const response = await fetch('/api/audio/play', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        fileName: fileName,
                        requestedBy: 'admin'
                    })
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    showLibraryActionMessage(
                        errorText || 'Не удалось добавить файл в очередь.',
                        'warning');

                    return;
                }

                showLibraryActionMessage(
                    `Файл "${fileName}" добавлен в очередь.`,
                    'success');

                await updateQueue();
            } catch {
                showLibraryActionMessage(
                    'Ошибка при обращении к серверу.',
                    'warning');
            } finally {
                if (button) {
                    button.disabled = false;
                    button.textContent = originalText;
                }
            }
        }

        let libraryActionMessageHideTimer;

        function showLibraryActionMessage(message, type) {
            const messageBlock = document.getElementById('library-action-message');

            if (!messageBlock) {
                return;
            }

            clearTimeout(libraryActionMessageHideTimer);

            messageBlock.textContent = message;
            messageBlock.className =
                `alert alert-${type} position-fixed top-0 end-0 m-3 shadow`;

            messageBlock.style.zIndex = '1080';
            messageBlock.style.minWidth = '320px';
            messageBlock.style.maxWidth = '480px';

            libraryActionMessageHideTimer = setTimeout(() => {
                messageBlock.classList.add('d-none');
            }, 1000);
        }

        document.querySelectorAll('.js-play-library-file')
            .forEach(button => {
                button.addEventListener('click', async () => {
                    const fileName = button.dataset.audioFileName;
                    await enqueueLibraryFile(fileName, button);
                });
            });

        async function enqueueTextToSpeech() {
            const textInput = document.getElementById('tts-text');
            const button = document.getElementById('tts-play-button');

            if (!textInput || !button) {
                return;
            }

            const text = textInput.value.trim();

            if (!text) {
                showTextToSpeechMessage(
                    'Введите текст сообщения.',
                    'warning');

                return;
            }

            const originalText = button.textContent;

            button.disabled = true;
            button.textContent = 'Добавление...';

            try {
                const response = await fetch('/api/tts/play', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        text: text,
                        requestedBy: 'admin'
                    })
                });

                if (!response.ok) {
                    const error = await response.text();

                    showTextToSpeechMessage(
                        error || 'Не удалось добавить текст в очередь.',
                        'warning');

                    return;
                }

                showTextToSpeechMessage(
                    'Текст добавлен в очередь на озвучивание.',
                    'success');

                textInput.value = '';
                updateTextToSpeechLength();
            }
            catch {
                showTextToSpeechMessage(
                    'Ошибка при обращении к серверу.',
                    'warning');
            }
            finally {
                button.disabled = false;
                button.textContent = originalText;
            }
        }

        function showTextToSpeechMessage(message, type) {
            const element = document.getElementById(
                'tts-action-message');

            if (!element) {
                return;
            }

            element.textContent = message;
            element.className = `alert alert-${type}`;
        }

        function updateTextToSpeechLength() {
            const textInput = document.getElementById('tts-text');
            const lengthElement = document.getElementById(
                'tts-text-length');

            if (!textInput || !lengthElement) {
                return;
            }

            lengthElement.textContent =
                `${textInput.value.length} символов`;
        }

        document.getElementById('tts-play-button')
            ?.addEventListener(
                'click',
                enqueueTextToSpeech);

        document.getElementById('tts-text')
            ?.addEventListener(
                'input',
                updateTextToSpeechLength);
        
        document.getElementById('tts-text')
            ?.addEventListener('keydown', event => {
                if (event.ctrlKey && event.key === 'Enter') {
                    event.preventDefault();
                    enqueueTextToSpeech();
                }
            });
        document.getElementById('stop-playback-button')?.addEventListener('click', stopCurrentPlayback);
        
        updatePlaybackStatus();
        updateQueue();

        setInterval(updatePlaybackStatus, 1000);
        setInterval(updateQueue, 1000);
    </script>
}