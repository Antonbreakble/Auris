@page
@using Auris.Host.Admin.Services
@model Auris.Host.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "Admin";
}

<div class="mb-4">
    <h1>Auris Admin</h1>
    <p class="text-muted mb-0">
        Панель управления локальным аудиосервисом.
    </p>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.QueueTab ? "active" : "")"
           asp-page="/Admin/Index"
           asp-route-tab="@AdminDashboardService.QueueTab">
            Текущая очередь
        </a>
    </li>

    <li class="nav-item">
        <a class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.LibraryTab ? "active" : "")"
           asp-page="/Admin/Index"
           asp-route-tab="@AdminDashboardService.LibraryTab">
            Аудиофайлы
        </a>
    </li>
</ul>

@if (Model.Dashboard.ActiveTab == AdminDashboardService.QueueTab)
{
    <partial name="~/Pages/Admin/Partials/_QueueTab.cshtml"
             model="Model.Dashboard.Queue" />
}

@if (Model.Dashboard.ActiveTab == AdminDashboardService.LibraryTab)
{
    <partial name="~/Pages/Admin/Partials/_LibraryTab.cshtml"
             model="Model.Dashboard.Library" />
}