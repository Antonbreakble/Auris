@page
@using Auris.Host.Admin.Services
@model Auris.Host.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "Admin";
}

<div class="mb-4">
    <h1 class="mb-2">@ProductBrand.Name</h1>
    <p class="text-muted mb-0">
        Панель управления локальным аудиосервисом.
    </p>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Сейчас воспроизводится</span>

        <div class="d-flex align-items-center gap-2">
            <button id="stop-playback-button"
                    type="button"
                    class="btn btn-sm btn-outline-danger d-none">
                Остановить
            </button>

            <span id="playback-status-badge"
                  class="badge text-bg-secondary">
                Idle
            </span>
        </div>
    </div>

    <div class="card-body">
        <div id="playback-current-file" class="fw-semibold">
            Сейчас ничего не воспроизводится.
        </div>

        <div id="playback-current-meta" class="text-muted small mt-1"></div>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.QueueTab ? "active" : "")"
           asp-page="/Admin/Index"
           asp-route-tab="@AdminDashboardService.QueueTab">
            Текущая очередь
        </a>
    </li>

    <li class="nav-item">
        <a class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.LibraryTab ? "active" : "")"
           asp-page="/Admin/Index"
           asp-route-tab="@AdminDashboardService.LibraryTab">
            Аудиофайлы
        </a>
    </li>
    
    <li class="nav-item">
        <a
            class="nav-link @(Model.Dashboard.ActiveTab == AdminDashboardService.TextToSpeechTab ? "active" : "")"
            asp-page="/Admin/Index"
            asp-route-tab="@AdminDashboardService.TextToSpeechTab">
            Синтез речи
        </a>
    </li>
</ul>

@if (Model.Dashboard.ActiveTab == AdminDashboardService.QueueTab)
{
    @await Html.PartialAsync("Partials/_QueueTab", Model.Dashboard.Queue)
}

@if (Model.Dashboard.ActiveTab == AdminDashboardService.LibraryTab)
{
    @await Html.PartialAsync("Partials/_LibraryTab", Model.Dashboard.Library)
}

@if (Model.Dashboard.ActiveTab == AdminDashboardService.TextToSpeechTab)
{
    @await Html.PartialAsync("Partials/_TextToSpeechTab")
}

@section Scripts {
    <script type="module"
            src="~/js/admin/index.js"
            asp-append-version="true">
    </script>
}