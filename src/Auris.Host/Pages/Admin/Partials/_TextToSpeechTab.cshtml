<div class="card">
    <div class="card-header">
        Синтез речи
    </div>

    <div class="card-body">
        <div
            id="tts-action-message"
            class="alert d-none"
            role="alert">
        </div>

        <div class="mb-3">
            <label
                for="tts-text"
                class="form-label">
                Текст сообщения
            </label>

            <textarea
                id="tts-text"
                class="form-control"
                rows="5"
                maxlength="1000"
                placeholder="Введите текст для озвучивания"></textarea>
        </div>

        <div class="d-flex align-items-center gap-3">
            <button
                id="tts-play-button"
                type="button"
                class="btn btn-primary">
                Озвучить
            </button>

            <span
                id="tts-text-length"
                class="text-muted small">
                0 символов
            </span>
        </div>
    </div>
</div>