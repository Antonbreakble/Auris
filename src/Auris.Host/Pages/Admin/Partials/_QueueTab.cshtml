@model Auris.Host.Admin.ViewModels.QueueTabViewModel

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h4 mb-1">Текущая очередь</h2>

            <div class="text-muted">
                Элементов в очереди: @Model.Count / @Model.Capacity
            </div>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary"
               asp-page="/Admin/Index"
               asp-route-tab="queue">
                Обновить
            </a>

            <form method="post" asp-page="/Admin/Index" asp-page-handler="ClearQueue">
                <button type="submit" class="btn btn-danger">
                    Очистить очередь
                </button>
            </form>
        </div>
    </div>

    @if (Model.Items.Count == 0)
    {
        <div class="alert alert-secondary">
            Очередь пуста.
        </div>
    }
    else
    {
        <table class="table table-striped align-middle">
            <thead>
            <tr>
                <th>Файл</th>
                <th>Добавлен</th>
                <th>Источник</th>
            </tr>
            </thead>

            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.FileName</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@item.CreatedBy</td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>