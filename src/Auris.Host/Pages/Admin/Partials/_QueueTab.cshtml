@model Auris.Host.Admin.ViewModels.QueueTabViewModel

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2 class="h4 mb-1">Текущая очередь</h2>

        <div class="text-muted">
            Элементов в очереди:
            <span id="queue-count">@Model.Count</span>
            /
            <span id="queue-capacity">@Model.Capacity</span>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button id="refresh-queue-button"
                type="button"
                class="btn btn-outline-secondary btn-sm">
            Обновить
        </button>

        <button id="clear-queue-button"
                type="button"
                class="btn btn-outline-danger btn-sm">
            Очистить очередь
        </button>
    </div>
</div>

<div id="queue-error"
     class="alert alert-warning d-none"
     role="alert">
    Не удалось получить состояние очереди.
</div>

<div id="queue-empty"
     class="alert alert-secondary @(Model.Items.Count == 0 ? "" : "d-none")">
    Очередь пуста.
</div>

<div id="queue-table-wrapper"
     class="table-responsive @(Model.Items.Count == 0 ? "d-none" : "")">
    <table class="table table-sm table-striped align-middle">
        <thead>
        <tr>
            <th>Файл</th>
            <th>Добавлен</th>
            <th>Источник</th>
        </tr>
        </thead>

        <tbody id="queue-table-body">
        @foreach (var item in Model.Items)
        {
            <tr data-queue-item-id="@item.Id">
                <td>@item.FileName</td>
                <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@item.CreatedBy</td>
            </tr>
        }
        </tbody>
    </table>
</div>